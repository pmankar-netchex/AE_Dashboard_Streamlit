# =========================
# AE Dashboard env template
# Copy to .env and edit
# =========================

# Environment: dev (no auth, identity from DEV_* below) | prod (Easy Auth)
ENV=dev

# Dev-only identity (ignored when ENV=prod)
DEV_ROLE=admin
DEV_USER_EMAIL=dev@local

# Bootstrap admin emails (comma-separated). Upserted as admins on startup.
BOOTSTRAP_ADMIN_EMAILS=

# ----- Salesforce (client-credentials flow) -----
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_LOGIN_URL=https://login.salesforce.com
SF_API_VERSION=v60.0

# ----- Azure Table Storage -----
# Leave empty in dev to use local soql_overrides.json fallback.
AZURE_STORAGE_CONNECTION_STRING=

# Production query write-protection. Set to true ONLY when you intend to edit
# SOQL templates from the running app. Default OFF for safety.
ALLOW_PROD_QUERY_WRITES=false

# ----- Email (SendGrid) -----
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=dashboard@example.com
SENDGRID_FROM_NAME=AE Dashboard

# ----- Scheduler -----
SCHEDULER_TZ=America/Chicago

# ----- CORS / internal -----
UI_ORIGIN=http://localhost:5173
INTERNAL_API_KEY=
